{
  "name": "pptyping",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/generate-static-routes.ts",
    "preview": "vite preview",
    "check:screen-lifecycle": "tsx scripts/check-screen-lifecycle.ts",
    "test:format": "prettier --check .",
    "test:unit": "node --import tsx --test tests/unit.tests.ts",
    "test:playwright": "playwright test",
    "test:all": "npm run test:format && npm run typecheck && npm run test:unit && npm run test:playwright",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && npm run check:screen-lifecycle",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  },
  "dependencies": {
    "tsx": "^4.21.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  }
}
