{
  "name": "pptyping",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check:screen-lifecycle": "tsx scripts/check-screen-lifecycle.ts",
    "test": "node --import tsx --test test/all.test.ts",
