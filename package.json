    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
